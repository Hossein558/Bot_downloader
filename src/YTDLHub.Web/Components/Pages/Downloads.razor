@page "/downloads"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using YTDLHub.Core.Interfaces
@using YTDLHub.Core.Enums
@using YTDLHub.Core.Models
@using YTDLHub.Infrastructure.Data
@using System.Security.Claims
@using System.Text.RegularExpressions
@inject IDownloadService DownloadService
@inject AppDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JS
@attribute [Authorize]
@implements IDisposable

<PageTitle>دانلود جدید — YTDLHub</PageTitle>

<div class="glass-card">
    <div class="card-title">
        <div style="display: flex; align-items: center; gap: 0.6rem;">
            <div class="card-title-icon"><i class="bi bi-cloud-arrow-down-fill"></i></div>
            ثبت دانلود جدید
        </div>
    </div>

    <EditForm Model="@Model" OnValidSubmit="HandleSubmit" FormName="download-form">
        <DataAnnotationsValidator />

        @if (!IsStepTwo)
        {
            <!-- Step 1: URL Input with live validation -->
            <div class="form-field" style="margin-bottom: 1.25rem;">
                <label class="form-label">
                    <i class="bi bi-link-45deg"></i>
                    لینک محتوا
                </label>
                <InputText @bind-Value="Model.Url"
                           @oninput="OnUrlInput"
                           class="@UrlInputCssClass"
                           placeholder="https://www.youtube.com/watch?v=... یا لینک اینستاگرام"
                           dir="ltr" />
                @if (UrlValidationError != null)
                {
                    <div style="font-size: 0.75rem; color: #f87171; margin-top: 0.4rem; display: flex; align-items: center; gap: 0.3rem;">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        @UrlValidationError
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(Message))
            {
                <div class="alert alert-@MessageType" style="margin-bottom: 1rem;">
                    <i class="bi bi-@(MessageType == "success" ? "check-circle-fill" : "exclamation-circle-fill")"></i>
                    @Message
                </div>
            }

            <div style="display: flex; justify-content: flex-end;">
                <button type="button"
                        class="btn btn-primary btn-lg"
                        disabled="@(IsCheckingVideo || string.IsNullOrWhiteSpace(Model.Url) || UrlValidationError != null)"
                        @onclick="CheckVideoAsync">
                    @if (IsCheckingVideo)
                    {
                        <span class="spinner"></span>
                        <span>در حال دریافت اطلاعات... (@CheckTimeout ثانیه)</span>
                    }
                    else
                    {
                        <i class="bi bi-search"></i>
                        <span>بررسی ویدیو</span>
                    }
                </button>
            </div>
        }
        else
        {
            <!-- Step 2: Info + Quality/Download -->

            <!-- Video info card -->
            @if (CheckedVideoInfo != null)
            {
                <div style="margin-bottom: 1.5rem; padding: 1rem; background: var(--bg-card-hover); border-radius: 8px; border: 1px solid var(--border-subtle);">
                    <div style="display: flex; gap: 1rem; align-items: flex-start;">
                        @if (!string.IsNullOrEmpty(CheckedVideoInfo.ThumbnailUrl))
                        {
                            <img src="@CheckedVideoInfo.ThumbnailUrl" alt="Thumbnail"
                                 style="width: 120px; border-radius: 6px; object-fit: cover; flex-shrink: 0;" />
                        }
                        <div style="min-width: 0;">
                            <h4 style="margin: 0 0 0.5rem 0; font-size: 1rem; color: var(--text-primary); word-break: break-word;">@CheckedVideoInfo.Title</h4>
                            <div style="font-size: 0.8rem; color: var(--text-muted);">
                                <i class="bi bi-person"></i> @CheckedVideoInfo.Uploader
                            </div>
                            @if (CheckedVideoInfo.Duration > TimeSpan.Zero)
                            {
                                <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.2rem;">
                                    <i class="bi bi-clock"></i>
                                    @((int)CheckedVideoInfo.Duration.TotalMinutes):@CheckedVideoInfo.Duration.Seconds.ToString("D2")
                                </div>
                            }
                            <!-- Platform badge -->
                            <div style="margin-top: 0.5rem;">
                                @if (CheckedVideoInfo.Platform == Platform.YouTube)
                                {
                                    <span style="font-size: 0.72rem; background: rgba(239,68,68,0.15); color: #ef4444; padding: 2px 8px; border-radius: 4px; font-weight: 600;">
                                        <i class="bi bi-youtube"></i> YouTube
                                    </span>
                                }
                                else if (CheckedVideoInfo.Platform == Platform.Instagram)
                                {
                                    <span style="font-size: 0.72rem; background: rgba(245,158,11,0.15); color: #f59e0b; padding: 2px 8px; border-radius: 4px; font-weight: 600;">
                                        <i class="bi bi-instagram"></i> Instagram
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (CheckedVideoInfo?.Platform == Platform.Instagram)
            {
                <!-- Instagram: skip quality selection — one-click download -->
                <div style="padding: 1rem; background: rgba(245,158,11,0.07); border: 1px solid rgba(245,158,11,0.25); border-radius: 8px; margin-bottom: 1.5rem; font-size: 0.85rem; color: var(--text-secondary);">
                    <i class="bi bi-info-circle-fill" style="color: #f59e0b;"></i>
                    اینستاگرام به‌طور خودکار با بهترین کیفیت ممکن دانلود می‌شود.
                </div>
            }
            else
            {
                <!-- YouTube / Other: full quality selector -->
                <div class="form-field" style="margin-bottom: 1.25rem;">
                    <label class="form-label">
                        <i class="bi bi-badge-hd-fill"></i>
                        کیفیت ویدیو
                    </label>

                    @if (CheckedVideoInfo?.Platform == Platform.YouTube && CheckedVideoInfo.YoutubeFormats.Any())
                    {
                        <InputSelect @bind-Value="Model.FormatId" class="form-input" dir="ltr">
                            @foreach (var fmt in CheckedVideoInfo.YoutubeFormats)
                            {
                                <option value="@fmt.FormatId">@fmt.DisplayName</option>
                            }
                        </InputSelect>
                    }
                    else
                    {
                        <InputSelect @bind-Value="Model.Quality" class="form-input" dir="ltr">
                            @foreach (var q in CheckedVideoInfo?.AvailableQualities ?? new List<VideoQuality>())
                            {
                                <option value="@q">@GetQualityName(q)</option>
                            }
                        </InputSelect>
                    }
                </div>
            }

            <!-- Folder selector (always shown) -->
            <div class="form-field" style="margin-bottom: 1.5rem;">
                <label class="form-label">
                    <i class="bi bi-folder-fill"></i>
                    ذخیره در پوشه
                    <span style="font-size: 0.72rem; color: var(--text-muted); margin-right: 0.4rem;">
                        (خودکار بر اساس پلتفرم انتخاب می‌شود)
                    </span>
                </label>
                <InputSelect @bind-Value="Model.FolderId" class="form-input">
                    <option value="">-- پوشه اصلی (دانلودها) --</option>
                    @foreach (var f in UserFolders)
                    {
                        <option value="@f.Id">@f.Name</option>
                    }
                </InputSelect>
            </div>

            @if (!string.IsNullOrEmpty(Message))
            {
                <div class="alert alert-@MessageType" style="margin-bottom: 1rem;">
                    <i class="bi bi-@(MessageType == "success" ? "check-circle-fill" : "exclamation-circle-fill")"></i>
                    @Message
                </div>
            }

            <div style="display: flex; justify-content: space-between; gap: 1rem;">
                <button type="button" class="btn btn-secondary btn-lg" @onclick="ResetForm" disabled="@IsSubmitting">
                    <i class="bi bi-arrow-right"></i>
                    بازگشت
                </button>
                <button type="submit" class="btn btn-primary btn-lg" disabled="@IsSubmitting">
                    @if (IsSubmitting)
                    {
                        <span class="spinner"></span>
                        <span>در حال پردازش...</span>
                    }
                    else if (CheckedVideoInfo?.Platform == Platform.Instagram)
                    {
                        <i class="bi bi-instagram"></i>
                        <span>دانلود پست اینستاگرام</span>
                    }
                    else
                    {
                        <i class="bi bi-cloud-arrow-down-fill"></i>
                        <span>شروع دانلود</span>
                    }
                </button>
            </div>
        }
    </EditForm>
</div>

<!-- Supported Platforms Info -->
<div class="glass-card">
    <div class="card-title">
        <div style="display: flex; align-items: center; gap: 0.6rem;">
            <div class="card-title-icon"><i class="bi bi-info-circle-fill"></i></div>
            پلتفرم‌های پشتیبانی‌شده
        </div>
    </div>
    <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
        @foreach (var platform in SupportedPlatforms)
        {
            <div style="display: flex; align-items: center; gap: 0.4rem; background: var(--bg-card-hover); border: 1px solid var(--border-subtle); border-radius: 8px; padding: 0.4rem 0.75rem; font-size: 0.78rem; color: var(--text-secondary);">
                <i class="bi @platform.Icon" style="color: @platform.Color;"></i>
                @platform.Name
            </div>
        }
    </div>
</div>

@code {
    // ── Regex patterns for client-side URL validation ─────────────────────────
    private static readonly Regex YoutubePattern = new(
        @"^(https?://)?(www\.)?(youtube\.com/(watch\?v=|shorts/|embed/|live/)|youtu\.be/)[^\s]+$",
        RegexOptions.IgnoreCase | RegexOptions.Compiled);

    private static readonly Regex InstagramPattern = new(
        @"^(https?://)?(www\.)?instagram\.com/(p|reel|tv|stories)/[^\s]+$",
        RegexOptions.IgnoreCase | RegexOptions.Compiled);

    // ── Component state ────────────────────────────────────────────────────────
    private DownloadFormModel Model = new();
    private bool IsSubmitting = false;
    private string Message = "";
    private string MessageType = "info";
    private string? UrlValidationError = null;

    // Computed CSS class — avoids Blazor RZ9986 (no inline ternaries in class attr)
    private string UrlInputCssClass => UrlValidationError != null ? "form-input input-error" : "form-input";

    private bool IsStepTwo = false;
    private bool IsCheckingVideo = false;
    private int CheckTimeout = 20;          // displayed countdown seconds
    private VideoInfo? CheckedVideoInfo;

    private Guid UserId;
    private List<UserFolder> UserFolders = new();

    private CancellationTokenSource? _checkCts;

    private List<PlatformInfo> SupportedPlatforms = new()
    {
        new() { Name = "YouTube",   Icon = "bi-youtube",   Color = "#ef4444" },
        new() { Name = "Instagram", Icon = "bi-instagram", Color = "#f59e0b" },
        new() { Name = "Twitter / X", Icon = "bi-twitter-x", Color = "#94a3b8" },
        new() { Name = "Facebook",  Icon = "bi-facebook",  Color = "#3b82f6" },
        new() { Name = "TikTok",    Icon = "bi-tiktok",    Color = "#06b6d4" },
        new() { Name = "SoundCloud",Icon = "bi-soundwave", Color = "#f97316" },
        new() { Name = "Vimeo",     Icon = "bi-vimeo",     Color = "#6366f1" },
        new() { Name = "و بیش از ۱۰۰۰ سایت دیگر", Icon = "bi-globe2", Color = "#10b981" },
    };

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var userIdStr = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(userIdStr, out UserId))
            {
                UserFolders = DbContext.Folders.Where(f => f.UserId == UserId).ToList();
            }
        }
    }

    // ── URL input & client-side validation ────────────────────────────────────

    private void OnUrlInput(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        var url = (e.Value?.ToString() ?? "").Trim();
        Model.Url = url;

        // Reset step state when URL changes
        IsStepTwo = false;
        CheckedVideoInfo = null;
        Message = "";
        UrlValidationError = null;

        if (string.IsNullOrWhiteSpace(url))
            return;

        // Enforce supported platforms only
        bool isYt  = YoutubePattern.IsMatch(url);
        bool isIg  = InstagramPattern.IsMatch(url);

        if (!isYt && !isIg)
        {
            UrlValidationError = "⚠️ لینک وارد شده پشتیبانی نمیشود. در حال حاضر فقط لینکهای YouTube و Instagram پشتیبانی میشوند.";
        }
    }

    // ── Step 1: Fetch video info with timeout ────────────────────────────────

    private async Task CheckVideoAsync()
    {
        if (string.IsNullOrWhiteSpace(Model.Url) || UrlValidationError != null)
            return;

        // Cancel any previous in-flight request
        _checkCts?.Cancel();
        _checkCts?.Dispose();
        _checkCts = new CancellationTokenSource(TimeSpan.FromSeconds(20));

        IsCheckingVideo = true;
        CheckTimeout    = 20;
        Message         = "";
        CheckedVideoInfo = null;
        StateHasChanged();

        try
        {
            await JS.InvokeVoidAsync("console.log",
                $"[YTDLHub] CheckVideoAsync started for: {Model.Url}");

            CheckedVideoInfo = await DownloadService.GetVideoInfoAsync(Model.Url, _checkCts.Token);
            IsStepTwo = true;

            await JS.InvokeVoidAsync("console.log",
                $"[YTDLHub] VideoInfo received — platform: {CheckedVideoInfo.Platform}, " +
                $"title: {CheckedVideoInfo.Title}, formats: {CheckedVideoInfo.YoutubeFormats.Count}");

            // Auto-select folder and default quality
            AutoSelectFolder(CheckedVideoInfo.Platform);

            if (CheckedVideoInfo.Platform == Platform.Instagram)
            {
                // Instagram: use Best quality — no user selection needed
                Model.Quality  = VideoQuality.Best;
                Model.FormatId = null;
            }
            else if (CheckedVideoInfo.Platform == Platform.YouTube && CheckedVideoInfo.YoutubeFormats.Any())
            {
                Model.FormatId = CheckedVideoInfo.YoutubeFormats.First().FormatId;
            }
            else if (CheckedVideoInfo.AvailableQualities.Any())
            {
                Model.Quality = CheckedVideoInfo.AvailableQualities.First();
            }
        }
        catch (OperationCanceledException)
        {
            var msg = $"[YTDLHub] CheckVideoAsync timed out after 20s for URL: {Model.Url}";
            await JS.InvokeVoidAsync("console.warn", msg);

            Message     = "⏱️ درخواست بیش از ۲۰ ثانیه طول کشید و لغو شد. لطفاً دوباره تلاش کنید یا اینترنت‌تان را بررسی نمایید.";
            MessageType = "error";
        }
        catch (Exception ex)
        {
            // Log full exception to browser console for debugging
            var fullMsg = $"[YTDLHub] Exception in CheckVideoAsync:\n{ex}";
            await JS.InvokeVoidAsync("console.error", fullMsg);

            // Show exact exception message in UI so the user can report it
            Message     = $"❌ خطا در دریافت اطلاعات ویدیو:\n{ex.Message}";
            MessageType = "error";
        }
        finally
        {
            IsCheckingVideo = false;
            StateHasChanged();
        }
    }

    // ── Folder auto-routing ────────────────────────────────────────────────────

    private void AutoSelectFolder(Platform platform)
    {
        var targetName = platform switch
        {
            Platform.YouTube   => "YouTube",
            Platform.Instagram => "Instagram",
            _                  => null
        };

        UserFolder? folder = targetName != null
            ? UserFolders.FirstOrDefault(f => f.Name == targetName)
            : null;

        folder ??= UserFolders.FirstOrDefault(f => f.IsDefault);
        Model.FolderId = folder?.Id;
    }

    // ── Reset ─────────────────────────────────────────────────────────────────

    private void ResetForm()
    {
        _checkCts?.Cancel();
        IsStepTwo        = false;
        CheckedVideoInfo = null;
        Message          = "";
        UrlValidationError = null;
        StateHasChanged();
    }

    // ── Step 2: Submit download ────────────────────────────────────────────────

    private async Task HandleSubmit()
    {
        IsSubmitting = true;
        Message      = "";
        StateHasChanged();

        try
        {
            // Final fallback auto-routing if user cleared folder selection
            if (Model.FolderId == null || Model.FolderId == Guid.Empty)
            {
                var platform = DownloadService.DetectPlatform(Model.Url);
                AutoSelectFolder(platform);
            }

            await DownloadService.StartDownloadAsync(
                Model.Url,
                Model.Quality,
                Model.FormatId,
                UserId,
                Model.FolderId == Guid.Empty ? null : Model.FolderId,
                CheckedVideoInfo?.Title,
                CheckedVideoInfo?.ThumbnailUrl);

            await JS.InvokeVoidAsync("console.log",
                $"[YTDLHub] Download queued for: {Model.Url}");

            Message     = "✅ دانلود با موفقیت در صف قرار گرفت! می‌توانید پیشرفت را در داشبورد دنبال کنید.";
            MessageType = "success";

            await Task.Delay(2500);

            Model            = new();
            IsStepTwo        = false;
            CheckedVideoInfo = null;
            Message          = "";
            UrlValidationError = null;
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.error",
                $"[YTDLHub] HandleSubmit exception: {ex}");
            Message     = $"❌ خطا در شروع دانلود: {ex.Message}";
            MessageType = "error";
        }
        finally
        {
            IsSubmitting = false;
            StateHasChanged();
        }
    }

    // ── Helpers ────────────────────────────────────────────────────────────────

    private string GetQualityName(VideoQuality q)
    {
        return q switch
        {
            VideoQuality.Best     => "بهترین کیفیت ممکن",
            VideoQuality.HD1080   => "1080p HD",
            VideoQuality.HD720    => "720p HD",
            VideoQuality.SD480    => "480p SD",
            VideoQuality.SD360    => "360p SD",
            VideoQuality.AudioMp3 => "فقط صدا (MP3)",
            VideoQuality.AudioM4A => "فقط صدا (M4A)",
            _                     => q.ToString()
        };
    }

    public void Dispose()
    {
        _checkCts?.Cancel();
        _checkCts?.Dispose();
    }

    // ── Models ─────────────────────────────────────────────────────────────────

    public class DownloadFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "لینک الزامی است.")]
        public string Url { get; set; } = "";
        public VideoQuality Quality { get; set; } = VideoQuality.Best;
        public string? FormatId { get; set; }
        public Guid? FolderId { get; set; }
    }

    public class PlatformInfo
    {
        public string Name  { get; set; } = "";
        public string Icon  { get; set; } = "";
        public string Color { get; set; } = "";
    }
}
