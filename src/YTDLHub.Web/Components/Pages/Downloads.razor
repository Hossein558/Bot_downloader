@page "/downloads"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using YTDLHub.Core.Interfaces
@using YTDLHub.Core.Enums
@using YTDLHub.Core.Models
@using YTDLHub.Infrastructure.Data
@inject IDownloadService DownloadService
@inject AppDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@attribute [Authorize]

<PageTitle>دانلود جدید - YTDLHub</PageTitle>

<div class="form-page">
    <div class="form-header">
        <div class="form-header-logo">
            <div class="company-logo">YTDLHub</div>
        </div>
        <div class="form-header-title">
            <h1>ثبت دانلود جدید</h1>
        </div>
        <div class="form-header-info text-center text-muted" style="font-size: 0.85rem; padding-left: 1rem;">
            فایل ویدیویی یا صوتی
        </div>
    </div>

    <div class="step-card">
        <div class="step-title d-flex justify-content-between align-items-center">
            <span>جزئیات دانلود</span>
            <i class="bi bi-cloud-arrow-down fs-5 text-muted"></i>
        </div>

        <EditForm Model="@Model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            
            <div class="row mb-4">
                <div class="col-md-12">
                    <div class="input-group-rtl align-items-start">
                        <label style="width: 150px; margin-top: 0.5rem;">لینک محتوا</label>
                        <div class="flex-grow-1 position-relative">
                            <i class="bi bi-link-45deg text-muted position-absolute" style="left: 12px; top: 10px; font-size: 1.2rem;"></i>
                            <InputText @bind-Value="Model.Url" @oninput="OnUrlInput" class="form-control-rtl" placeholder="https://..." dir="ltr" />
                            <ValidationMessage For="@(() => Model.Url)" class="text-danger mt-1" style="font-size: 12px;" />
                        </div>
                    </div>
                </div>
            </div>

            @if (IsYoutube)
            {
                <div class="row mb-4">
                    <div class="col-md-12">
                        <div class="input-group-rtl">
                            <label style="width: 150px;">کیفیت ویدیو</label>
                            <div class="flex-grow-1">
                                <InputSelect @bind-Value="Model.Quality" class="form-control-rtl" dir="ltr">
                                    @foreach (var q in Qualities)
                                    {
                                        <option value="@q.Value">@q.Name</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="row mb-4">
                <div class="col-md-12">
                    <div class="input-group-rtl">
                        <label style="width: 150px;">ذخیره در پوشه</label>
                        <div class="flex-grow-1">
                            <InputSelect @bind-Value="Model.FolderId" class="form-control-rtl">
                                <option value="">-- پوشه اصلی --</option>
                                @foreach (var f in UserFolders)
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                </div>
            </div>

            <hr style="border-color: var(--border); margin: 2rem 0 1.5rem;" />

            <div class="d-flex justify-content-end">
                <button type="submit" class="btn-primary-rtl btn-lg d-flex align-items-center gap-2" disabled="@IsSubmitting">
                    @if (IsSubmitting)
                    {
                        <span class="spinner"></span>
                        <span>در حال پردازش...</span>
                    }
                    else
                    {
                        <i class="bi bi-cloud-arrow-down-fill"></i>
                        <span>شروع دانلود</span>
                    }
                </button>
            </div>
        </EditForm>
        
        @if (!string.IsNullOrEmpty(Message))
        {
            <div class="alert-@MessageType mt-4">
                @Message
            </div>
        }
    </div>
</div>

@code {
    private DownloadFormModel Model = new();
    private bool IsSubmitting = false;
    private string Message = "";
    private string MessageType = "info";
    private bool IsYoutube = false;
    
    private Guid UserId;
    private List<UserFolder> UserFolders = new();

    private List<QualityOption> Qualities = new List<QualityOption>
    {
        new QualityOption { Name = "Best Available (Default)", Value = VideoQuality.Best },
        new QualityOption { Name = "1080p HD", Value = VideoQuality.HD1080 },
        new QualityOption { Name = "720p HD", Value = VideoQuality.HD720 },
        new QualityOption { Name = "480p SD", Value = VideoQuality.SD480 },
        new QualityOption { Name = "360p SD", Value = VideoQuality.SD360 },
        new QualityOption { Name = "Audio Only (MP3)", Value = VideoQuality.AudioMp3 },
        new QualityOption { Name = "Audio Only (M4A)", Value = VideoQuality.AudioM4A }
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var userIdStr = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(userIdStr, out UserId))
            {
                UserFolders = DbContext.Folders.Where(f => f.UserId == UserId).ToList();
            }
        }
    }

    private void OnUrlInput(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        var url = e.Value?.ToString() ?? "";
        IsYoutube = url.Contains("youtube.com", StringComparison.OrdinalIgnoreCase) || 
                    url.Contains("youtu.be", StringComparison.OrdinalIgnoreCase);
    }

    private async Task HandleSubmit()
    {
        IsSubmitting = true;
        Message = "";
        StateHasChanged();

        try
        {
            await DownloadService.StartDownloadAsync(
                Model.Url, 
                IsYoutube ? Model.Quality : VideoQuality.Best, 
                null, 
                UserId, 
                Model.FolderId == Guid.Empty ? null : Model.FolderId);
                
            Message = "دانلود با موفقیت در صف قرار گرفت! به داشبورد یا تاریخچه مراجعه کنید.";
            MessageType = "success";
            Model.Url = ""; // Reset form
            IsYoutube = false;
        }
        catch (Exception ex)
        {
            Message = $"خطا: {ex.Message}";
            MessageType = "error";
        }
        finally
        {
            IsSubmitting = false;
            StateHasChanged();
        }
    }

    public class DownloadFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "لینک الزامی است.")]
        [System.ComponentModel.DataAnnotations.Url(ErrorMessage = "لینک معتبر نیست.")]
        public string Url { get; set; } = "";
        
        public VideoQuality Quality { get; set; } = VideoQuality.Best;
        
        public Guid? FolderId { get; set; }
    }

    public class QualityOption
    {
        public string Name { get; set; } = "";
        public VideoQuality Value { get; set; }
    }
}
