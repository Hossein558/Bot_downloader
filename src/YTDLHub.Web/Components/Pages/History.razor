@page "/history"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using YTDLHub.Core.Models
@using YTDLHub.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize]

<PageTitle>تاریخچه دانلودها - YTDLHub</PageTitle>

<div class="form-page">
    <div class="form-header">
        <div class="form-header-logo">
            <div class="company-logo">YTDLHub</div>
        </div>
        <div class="form-header-title">
            <h1>تاریخچه دانلودها</h1>
        </div>
        <div class="form-header-info text-center text-muted" style="font-size: 0.85rem; padding-left: 1rem;">
            فایل‌های دانلود شده (تا ۷ روز نگهداری می‌شوند)
        </div>
    </div>

    <div class="step-card">
        <div class="step-title d-flex justify-content-between align-items-center">
            <span>لیست دانلودهای گذشته</span>
            <span class="badge badge-queued">@Jobs.Count() مورد</span>
        </div>

        @if (IsLoading)
        {
            <div class="empty-state">
                <span class="spinner" style="width: 48px; height: 48px; border-width: 4px;"></span>
                <div class="empty-title mt-3">در حال دریافت تاریخچه...</div>
            </div>
        }
        else if (!Jobs.Any())
        {
            <div class="empty-state">
                <i class="bi bi-clock-history empty-icon"></i>
                <div class="empty-title">تاریخچه خالی است.</div>
                <div class="empty-sub">شما هنوز هیچ فایلی دانلود نکرده‌اید.</div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="dl-table">
                    <thead>
                        <tr>
                            <th>نام فایل / لینک</th>
                            <th>پلتفرم</th>
                            <th>حجم</th>
                            <th>تاریخ</th>
                            <th>وضعیت</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Jobs)
                        {
                            <tr>
                                <td>
                                    <div class="dl-title" dir="ltr" style="text-align: left;">@(job.FileName ?? job.Url)</div>
                                </td>
                                <td>
                                    @if (job.Platform == YTDLHub.Core.Enums.Platform.YouTube)
                                    {
                                        <i class="bi bi-youtube text-danger fs-5"></i>
                                    }
                                    else if (job.Platform == YTDLHub.Core.Enums.Platform.Instagram)
                                    {
                                        <i class="bi bi-instagram text-warning fs-5"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-link-45deg text-primary fs-5"></i>
                                    }
                                </td>
                                <td>
                                    <span class="badge badge-queued" dir="ltr">
                                        @(job.FileSizeBytes > 0 ? $"{(job.FileSizeBytes / 1024.0 / 1024.0):F1} MB" : "-")
                                    </span>
                                </td>
                                <td class="text-muted" style="font-size: 12px;" dir="ltr">
                                    @job.CompletedAt?.ToString("yyyy/MM/dd HH:mm")
                                </td>
                                <td>
                                    @if (job.Status == YTDLHub.Core.Enums.JobStatus.Completed)
                                    {
                                        <span class="badge badge-completed">تکمیل شده</span>
                                    }
                                    else if (job.Status == YTDLHub.Core.Enums.JobStatus.Failed)
                                    {
                                        <span class="badge badge-failed">خطا</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-queued">لغو شده</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private bool IsLoading = true;
    private Guid UserId;
    private List<DownloadJob> Jobs = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var userIdStr = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(userIdStr, out UserId))
            {
                await LoadHistory();
            }
        }
    }

    private async Task LoadHistory()
    {
        IsLoading = true;
        // Fetch from DB
        Jobs = await DbContext.DownloadJobs
            .Where(j => j.UserId == UserId && (j.Status == YTDLHub.Core.Enums.JobStatus.Completed || j.Status == YTDLHub.Core.Enums.JobStatus.Failed))
            .OrderByDescending(j => j.CreatedAt)
            .Take(50)
            .ToListAsync();
            
        IsLoading = false;
    }
}
