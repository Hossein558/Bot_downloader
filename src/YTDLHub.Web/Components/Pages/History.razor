@page "/history"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using YTDLHub.Core.Models
@using YTDLHub.Core.Enums
@using YTDLHub.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject AppDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize]

<PageTitle>تاریخچه دانلودها — YTDLHub</PageTitle>

<!-- Filter Bar -->
<div class="glass-card" style="padding: 1rem 1.5rem;">
    <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;">
        <div style="flex: 1; min-width: 200px;">
            <input type="text" class="form-input" placeholder="🔍 جستجو در عنوان یا لینک..." @bind="SearchQuery" @bind:event="oninput" @onkeyup="ApplyFilter" />
        </div>
        <select class="form-input" style="width: auto; min-width: 140px;" @bind="FilterStatus" @bind:after="ApplyFilter">
            <option value="">همه وضعیت‌ها</option>
            <option value="Completed">تکمیل‌شده</option>
            <option value="Failed">ناموفق</option>
        </select>
        <select class="form-input" style="width: auto; min-width: 140px;" @bind="FilterPlatform" @bind:after="ApplyFilter">
            <option value="">همه پلتفرم‌ها</option>
            <option value="YouTube">YouTube</option>
            <option value="Instagram">Instagram</option>
            <option value="Other">سایر</option>
        </select>
        <span style="font-size: 0.78rem; color: var(--text-muted); white-space: nowrap;">
            @FilteredJobs.Count مورد یافت شد
        </span>
    </div>
</div>

<div class="glass-card">
    <div class="card-title">
        <div style="display: flex; align-items: center; gap: 0.6rem;">
            <div class="card-title-icon"><i class="bi bi-clock-history"></i></div>
            تاریخچه دانلودها
        </div>
        <span class="badge badge-queued">@AllJobs.Count مورد</span>
    </div>

    @if (IsLoading)
    {
        <div class="empty-state">
            <span class="spinner" style="width: 36px; height: 36px; border-width: 3px;"></span>
            <div class="empty-title" style="margin-top: 1rem;">در حال بارگذاری...</div>
        </div>
    }
    else if (!FilteredJobs.Any())
    {
        <div class="empty-state">
            <i class="bi bi-clock-history empty-icon"></i>
            <div class="empty-title">
                @(AllJobs.Count == 0 ? "تاریخچه خالی است" : "نتیجه‌ای یافت نشد")
            </div>
            <div class="empty-sub">
                @(AllJobs.Count == 0 ? "هنوز هیچ فایلی دانلود نکرده‌اید" : "فیلتر خود را تغییر دهید")
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="dl-table">
                <thead>
                    <tr>
                        <th>کاور</th>
                        <th>عنوان / فایل</th>
                        <th>پلتفرم</th>
                        <th>کیفیت</th>
                        <th>حجم</th>
                        <th>تاریخ</th>
                        <th>وضعیت</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in FilteredJobs)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(job.ThumbnailUrl))
                                {
                                    <img src="@job.ThumbnailUrl" class="img-thumbnail" style="width: 80px; height: auto; border-radius: 6px; object-fit: cover;" alt="کاور ویدیو" />
                                }
                                else
                                {
                                    <div style="width: 80px; height: 45px; background: var(--bg-card-hover); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: var(--text-muted); font-size: 0.8rem;">ندارد</div>
                                }
                            </td>
                            <td style="max-width: 280px;">
                                <div class="dl-title" dir="ltr" style="text-align: left; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @(job.VideoTitle ?? job.FileName ?? job.Url)
                                </div>
                                <div class="dl-url">@job.Url</div>
                            </td>
                            <td>
                                @if (job.Platform == Platform.YouTube)
                                {
                                    <i class="bi bi-youtube" style="color: #ef4444; font-size: 1.1rem;"></i>
                                }
                                else if (job.Platform == Platform.Instagram)
                                {
                                    <i class="bi bi-instagram" style="color: #f59e0b; font-size: 1.1rem;"></i>
                                }
                                else
                                {
                                    <i class="bi bi-link-45deg" style="color: var(--brand-primary); font-size: 1.1rem;"></i>
                                }
                            </td>
                            <td>
                                <span class="badge badge-queued" dir="ltr">@job.Quality.ToString()</span>
                            </td>
                            <td>
                                <span dir="ltr" style="font-size: 0.78rem; color: var(--text-secondary);">
                                    @(job.FileSizeBytes > 0 ? $"{(job.FileSizeBytes / 1024.0 / 1024.0):F1} MB" : "—")
                                </span>
                            </td>
                            <td style="font-size: 0.75rem; color: var(--text-muted);" dir="ltr">
                                @((job.CompletedAt ?? job.CreatedAt).ToString("yyyy/MM/dd HH:mm"))
                            </td>
                            <td>
                                @if (job.Status == JobStatus.Completed)
                                {
                                    <span class="badge badge-completed">
                                        <i class="bi bi-check-circle-fill"></i>
                                        تکمیل‌شده
                                    </span>
                                }
                                else if (job.Status == JobStatus.Failed)
                                {
                                    <span class="badge badge-failed">
                                        <i class="bi bi-x-circle-fill"></i>
                                        خطا
                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-cancelled">لغو‌شده</span>
                                }
                                @if (job.Status == JobStatus.Completed)
                                {
                                    <div style="margin-top: 8px;">
                                        <a href="/api/Files/download/@job.Id" class="btn btn-sm" style="background-color: var(--brand-primary); color: white; border-radius: 6px; padding: 4px 12px; font-size: 0.8rem; text-decoration: none; display: inline-flex; align-items: center; gap: 4px;" target="_blank">
                                            <i class="bi bi-download"></i>
                                            دانلود فایل
                                        </a>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private bool IsLoading = true;
    private Guid UserId;
    private List<DownloadJob> AllJobs = new();
    private List<DownloadJob> FilteredJobs = new();
    private string SearchQuery = "";
    private string FilterStatus = "";
    private string FilterPlatform = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var userIdStr = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(userIdStr, out UserId))
            {
                await LoadHistory();
            }
        }
    }

    private async Task LoadHistory()
    {
        IsLoading = true;
        AllJobs = await DbContext.DownloadJobs
            .Where(j => j.UserId == UserId &&
                       (j.Status == JobStatus.Completed || j.Status == JobStatus.Failed || j.Status == JobStatus.Cancelled))
            .OrderByDescending(j => j.CreatedAt)
            .Take(200)
            .ToListAsync();

        IsLoading = false;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        var query = AllJobs.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(SearchQuery))
        {
            var q = SearchQuery.Trim().ToLower();
            query = query.Where(j =>
                (j.VideoTitle?.ToLower().Contains(q) ?? false) ||
                (j.FileName?.ToLower().Contains(q) ?? false) ||
                (j.Url?.ToLower().Contains(q) ?? false));
        }

        if (!string.IsNullOrEmpty(FilterStatus))
        {
            if (Enum.TryParse<JobStatus>(FilterStatus, out var statusEnum))
                query = query.Where(j => j.Status == statusEnum);
        }

        if (!string.IsNullOrEmpty(FilterPlatform))
        {
            if (FilterPlatform == "Other")
                query = query.Where(j => j.Platform != Platform.YouTube && j.Platform != Platform.Instagram);
            else if (Enum.TryParse<Platform>(FilterPlatform, out var platformEnum))
                query = query.Where(j => j.Platform == platformEnum);
        }

        FilteredJobs = query.ToList();
    }
}
