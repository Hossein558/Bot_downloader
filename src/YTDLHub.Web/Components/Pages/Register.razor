@page "/register"
@layout EmptyLayout
@rendermode InteractiveServer
@using YTDLHub.Core.Interfaces
@inject IAuthService AuthService
@inject NavigationManager Nav

<PageTitle>ثبت‌نام — YTDLHub</PageTitle>

<div class="auth-shell">
    <div class="auth-bg-glow auth-bg-glow-register"></div>

    <div class="auth-card">
        <div class="auth-brand">
            <div class="auth-logo-wrap">
                <i class="bi bi-cloud-arrow-down-fill"></i>
            </div>
            <h1 class="auth-title">YTDLHub</h1>
            <p class="auth-subtitle">پنل حرفه‌ای دانلود محتوا</p>
        </div>

        <div class="auth-form-section">
            <h2 class="auth-form-title">ایجاد حساب جدید</h2>
            <p class="auth-form-hint">پس از ثبت‌نام، تکمیل اطلاعات پروفایل الزامی است.</p>

            @if (Step == 1)
            {
                <EditForm Model="Model" OnValidSubmit="HandleRegister" FormName="register-form">
                    <div class="auth-field">
                        <label class="auth-label">
                            <i class="bi bi-person-fill"></i>
                            نام کاربری
                        </label>
                        <InputText @bind-Value="Model.Username"
                                   class="auth-input"
                                   placeholder="مثلاً: john_doe"
                                   autocomplete="username"
                                   dir="ltr" />
                        <span class="auth-field-hint">فقط حروف انگلیسی، اعداد و _ — حداقل ۳ کاراکتر</span>
                    </div>

                    <div class="auth-field">
                        <label class="auth-label">
                            <i class="bi bi-lock-fill"></i>
                            رمز عبور
                        </label>
                        <div class="auth-input-wrap">
                            <InputText @bind-Value="Model.Password"
                                       type="@(ShowPassword ? "text" : "password")"
                                       class="auth-input"
                                       placeholder="حداقل ۶ کاراکتر"
                                       autocomplete="new-password"
                                       dir="ltr" />
                            <button type="button" class="auth-eye-btn" @onclick="() => ShowPassword = !ShowPassword" tabindex="-1">
                                <i class="bi @(ShowPassword ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                    </div>

                    <div class="auth-field">
                        <label class="auth-label">
                            <i class="bi bi-shield-lock-fill"></i>
                            تکرار رمز عبور
                        </label>
                        <InputText @bind-Value="Model.ConfirmPassword"
                                   type="password"
                                   class="auth-input"
                                   placeholder="رمز عبور را دوباره وارد کنید"
                                   dir="ltr" />
                    </div>

                    @if (!string.IsNullOrEmpty(Error))
                    {
                        <div class="auth-alert auth-alert-error">
                            <i class="bi bi-exclamation-circle-fill"></i>
                            @Error
                        </div>
                    }

                    <button type="submit" class="auth-btn-primary" disabled="@IsLoading">
                        @if (IsLoading)
                        {
                            <span class="auth-spinner"></span>
                            <span>در حال ثبت‌نام...</span>
                        }
                        else
                        {
                            <i class="bi bi-person-check-fill"></i>
                            <span>ثبت‌نام</span>
                        }
                    </button>
                </EditForm>
            }
            else
            {
                <div class="auth-success-box">
                    <div class="auth-success-icon">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <h3>ثبت‌نام موفق!</h3>
                    <p>حساب شما ایجاد شد. در حال انتقال به صفحه ورود...</p>
                </div>
            }

            <div class="auth-divider">
                <span>قبلاً ثبت‌نام کرده‌اید؟</span>
            </div>

            <a href="/login" class="auth-btn-secondary">
                <i class="bi bi-box-arrow-in-left"></i>
                ورود به حساب
            </a>
        </div>
    </div>
</div>

@code {
    private RegisterModel Model = new();
    private bool IsLoading = false;
    private bool ShowPassword = false;
    private string Error = string.Empty;
    private int Step = 1;

    private async Task HandleRegister()
    {
        Error = string.Empty;

        if (string.IsNullOrWhiteSpace(Model.Username) || Model.Username.Length < 3)
        {
            Error = "نام کاربری باید حداقل ۳ کاراکتر داشته باشد.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Model.Password) || Model.Password.Length < 6)
        {
            Error = "رمز عبور باید حداقل ۶ کاراکتر داشته باشد.";
            return;
        }

        if (Model.Password != Model.ConfirmPassword)
        {
            Error = "رمز عبور و تکرار آن یکسان نیستند.";
            return;
        }

        IsLoading = true;
        StateHasChanged();

        var (success, error) = await AuthService.RegisterAsync(Model.Username, Model.Password);

        IsLoading = false;

        if (success)
        {
            Step = 2;
            StateHasChanged();

            await Task.Delay(1500);
            Nav.NavigateTo("/login");
        }
        else
        {
            Error = error ?? "خطایی رخ داد. لطفاً دوباره تلاش کنید.";
        }
    }

    public class RegisterModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
