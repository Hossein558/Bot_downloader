@page "/"
@rendermode InteractiveServer
@using System.Threading
@using YTDLHub.Core.Interfaces
@using YTDLHub.Core.Models
@using YTDLHub.Core.Enums
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@implements IDisposable
@inject IDownloadService DownloadService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@attribute [Authorize]

<PageTitle>داشبورد — YTDLHub</PageTitle>

@if (!IsProfileComplete)
{
    <div class="alert alert-warning" style="margin-bottom: 1.5rem; border-radius: 12px; font-size: 0.85rem;">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>
            <strong>پروفایل شما ناقص است!</strong>
            برای استفاده از امکانات دانلود، لطفاً ابتدا اطلاعات پروفایل خود را تکمیل کنید.
            <a href="/profile/setup" style="color: var(--warning); font-weight: 700; text-decoration: underline; margin-right: 0.5rem;">تکمیل پروفایل</a>
        </div>
    </div>
}

<!-- Stats -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon stat-icon-purple">
            <i class="bi bi-cloud-arrow-down-fill"></i>
        </div>
        <div>
            <div class="stat-val">@ActiveJobsCount</div>
            <div class="stat-label">دانلود فعال</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon stat-icon-green">
            <i class="bi bi-check-circle-fill"></i>
        </div>
        <div>
            <div class="stat-val">@CompletedJobsCount</div>
            <div class="stat-label">تکمیل‌شده</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon stat-icon-orange">
            <i class="bi bi-exclamation-circle-fill"></i>
        </div>
        <div>
            <div class="stat-val">@FailedJobsCount</div>
            <div class="stat-label">ناموفق</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon stat-icon-cyan">
            <i class="bi bi-collection-fill"></i>
        </div>
        <div>
            <div class="stat-val">@TotalJobsCount</div>
            <div class="stat-label">کل دانلودها</div>
        </div>
    </div>
</div>

<!-- Active Downloads -->
<div class="glass-card">
    <div class="card-title">
        <div style="display: flex; align-items: center; gap: 0.6rem;">
            <div class="card-title-icon"><i class="bi bi-activity"></i></div>
            دانلودهای فعال
        </div>
        <span class="badge badge-primary">@ActiveJobs.Count() مورد</span>
    </div>

    @if (!ActiveJobs.Any())
    {
        <div class="empty-state">
            <i class="bi bi-inbox empty-icon"></i>
            <div class="empty-title">هیچ دانلودی در حال انجام نیست</div>
            <div class="empty-sub">برای شروع دانلود، به بخش «دانلود جدید» بروید</div>
            <a href="/downloads" class="btn btn-primary btn-sm" style="margin-top: 1rem; display: inline-flex;">
                <i class="bi bi-plus-lg"></i>
                دانلود جدید
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="dl-table">
                <thead>
                    <tr>
                        <th>پلتفرم</th>
                        <th>کاور</th>
                        <th>عنوان / لینک</th>
                        <th>کیفیت</th>
                        <th>وضعیت</th>
                        <th style="width: 20%;">پیشرفت</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in ActiveJobs)
                    {
                        <tr>
                            <td>
                                @if (job.Platform == Platform.YouTube)
                                {
                                    <i class="bi bi-youtube" style="color: #ef4444; font-size: 1.1rem;"></i>
                                }
                                else if (job.Platform == Platform.Instagram)
                                {
                                    <i class="bi bi-instagram" style="color: #f59e0b; font-size: 1.1rem;"></i>
                                }
                                else
                                {
                                    <i class="bi bi-link-45deg" style="color: var(--brand-primary); font-size: 1.1rem;"></i>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(job.ThumbnailUrl))
                                {
                                    <img src="@job.ThumbnailUrl" class="img-thumbnail" style="width: 80px; height: auto; border-radius: 6px; object-fit: cover;" alt="کاور ویدیو" />
                                }
                                else
                                {
                                    <div style="width: 80px; height: 45px; background: var(--bg-card-hover); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: var(--text-muted); font-size: 0.8rem;">ندارد</div>
                                }
                            </td>
                            <td>
                                <div class="dl-title">@(job.VideoTitle ?? "در حال بارگذاری...")</div>
                                <div class="dl-url">@job.Url</div>
                            </td>
                            <td><span class="badge badge-queued">@job.Quality.ToString()</span></td>
                            <td>
                                @if (job.Status == JobStatus.Downloading)
                                {
                                    <span class="badge badge-downloading">در حال دانلود</span>
                                    <div style="font-size: 0.7rem; color: var(--text-muted); margin-top: 3px; direction: ltr; text-align: left;">@job.SpeedDisplay | @job.EtaDisplay</div>
                                }
                                else if (job.Status == JobStatus.Merging)
                                {
                                    <span class="badge badge-merging">در حال ادغام</span>
                                }
                                else
                                {
                                    <span class="badge badge-queued">@job.Status</span>
                                }
                            </td>
                            <td>
                                @if (job.Status == JobStatus.Downloading || job.Status == JobStatus.Merging)
                                {
                                    <div class="progress-bar-wrap">
                                        <div class="progress-bar-fill" style="width: @(job.Progress)%"></div>
                                    </div>
                                    <div style="font-size: 0.68rem; color: var(--text-muted); margin-top: 3px; direction: ltr; text-align: right;">@job.Progress%</div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Quick Actions -->
<div class="glass-card">
    <div class="card-title">
        <div style="display: flex; align-items: center; gap: 0.6rem;">
            <div class="card-title-icon"><i class="bi bi-lightning-fill"></i></div>
            دسترسی سریع
        </div>
    </div>
    <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <a href="/downloads" class="btn btn-primary">
            <i class="bi bi-cloud-arrow-down-fill"></i>
            دانلود جدید
        </a>
        <a href="/history" class="btn btn-secondary">
            <i class="bi bi-clock-history"></i>
            تاریخچه دانلودها
        </a>
        <a href="/folders" class="btn btn-secondary">
            <i class="bi bi-folder2-open"></i>
            پوشه‌های من
        </a>
        @if (!IsProfileComplete)
        {
            <a href="/profile/setup" class="btn btn-ghost" style="border-color: var(--warning); color: var(--warning);">
                <i class="bi bi-person-badge-fill"></i>
                تکمیل پروفایل
            </a>
        }
    </div>
</div>

@code {
    private IEnumerable<DownloadJob> ActiveJobs = new List<DownloadJob>();
    private Guid UserId;
    private bool IsProfileComplete = true;

    private PeriodicTimer? _timer;
    private CancellationTokenSource _cts = new();

    private int ActiveJobsCount => DownloadService.GetAllJobs()
        .Count(j => j.UserId == UserId &&
                    (j.Status == JobStatus.Downloading || j.Status == JobStatus.Merging || j.Status == JobStatus.Queued));

    private int CompletedJobsCount => DownloadService.GetAllJobs()
        .Count(j => j.UserId == UserId && j.Status == JobStatus.Completed);

    private int FailedJobsCount => DownloadService.GetAllJobs()
        .Count(j => j.UserId == UserId && j.Status == JobStatus.Failed);

    private int TotalJobsCount => DownloadService.GetAllJobs()
        .Count(j => j.UserId == UserId);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var userIdStr = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(userIdStr, out UserId))
            {
                var profileClaim = authState.User.FindFirstValue("IsProfileComplete");
                IsProfileComplete = profileClaim == "True";

                RefreshData();
                StartPolling();
            }
        }
    }

    private void StartPolling()
    {
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = Task.Run(async () =>
        {
            try
            {
                while (await _timer.WaitForNextTickAsync(_cts.Token))
                {
                    RefreshData();
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    private void RefreshData()
    {
        ActiveJobs = DownloadService.GetAllJobs()
            .Where(j => j.UserId == UserId &&
                        j.Status != JobStatus.Completed &&
                        j.Status != JobStatus.Failed &&
                        j.Status != JobStatus.Cancelled)
            .OrderByDescending(j => j.CreatedAt)
            .ToList();
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        _timer?.Dispose();
    }
}
