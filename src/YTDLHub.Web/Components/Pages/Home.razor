@page "/"
@using System.Timers
@using YTDLHub.Core.Interfaces
@using YTDLHub.Core.Models
@using YTDLHub.Core.Enums
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable
@inject IDownloadService DownloadService
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize]

<PageTitle>داشبورد - YTDLHub</PageTitle>

<div class="form-page">
    <div class="form-header">
        <div class="form-header-logo">
            <div class="company-logo">YTDLHub</div>
        </div>
        <div class="form-header-title">
            <h1>داشبورد مدیریت دانلودها</h1>
        </div>
        <div class="form-header-info text-center text-muted" style="font-size: 0.85rem; padding-left: 1rem;">
            وضعیت: آنلاین
        </div>
    </div>

    <div class="step-card">
        <div class="step-title d-flex justify-content-between align-items-center">
            <span>دانلودهای در حال انجام</span>
            <span class="badge badge-downloading">@Jobs.Count() مورد</span>
        </div>

        @if (!Jobs.Any())
        {
            <div class="empty-state">
                <i class="bi bi-inbox empty-icon"></i>
                <div class="empty-title">هیچ دانلودی در حال انجام نیست.</div>
                <div class="empty-sub">برای شروع، به بخش "دانلود جدید" بروید.</div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="dl-table">
                    <thead>
                        <tr>
                            <th>پلتفرم</th>
                            <th>عنوان / لینک</th>
                            <th>کیفیت</th>
                            <th>وضعیت</th>
                            <th>پیشرفت</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Jobs)
                        {
                            <tr>
                                <td>
                                    @if (job.Platform == Platform.YouTube)
                                    {
                                        <i class="bi bi-youtube text-danger fs-5"></i>
                                    }
                                    else if (job.Platform == Platform.Instagram)
                                    {
                                        <i class="bi bi-instagram text-warning fs-5"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-link-45deg text-primary fs-5"></i>
                                    }
                                </td>
                                <td>
                                    <div class="dl-title" dir="ltr" style="text-align: left;">@(job.VideoTitle ?? job.Url)</div>
                                </td>
                                <td><span class="badge badge-queued">@job.Quality.ToString()</span></td>
                                <td>
                                    @if (job.Status == JobStatus.Downloading)
                                    {
                                        <span class="badge badge-downloading">@job.Status</span>
                                        <div class="text-muted mt-1" dir="ltr" style="font-size: 10px;">@job.SpeedDisplay | @job.EtaDisplay</div>
                                    }
                                    else if (job.Status == JobStatus.Merging)
                                    {
                                        <span class="badge badge-merging">@job.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-queued">@job.Status</span>
                                    }
                                </td>
                                <td style="width: 25%;">
                                    @if (job.Status == JobStatus.Downloading || job.Status == JobStatus.Merging)
                                    {
                                        <div class="progress-bar-wrap mt-1">
                                            <div class="progress-bar-fill" style="width: @(job.Progress)%"></div>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private IEnumerable<DownloadJob> Jobs = new List<DownloadJob>();
    private Timer? _timer;
    private Guid UserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var userIdStr = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(userIdStr, out UserId))
            {
                RefreshData();
                _timer = new Timer(1000);
                _timer.Elapsed += (sender, args) =>
                {
                    RefreshData();
                    InvokeAsync(StateHasChanged);
                };
                _timer.Start();
            }
        }
    }

    private void RefreshData()
    {
        Jobs = DownloadService.GetAllJobs()
            .Where(j => j.UserId == UserId && j.Status != JobStatus.Completed && j.Status != JobStatus.Failed)
            .OrderByDescending(j => j.CreatedAt)
            .ToList();
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
