@page "/"
@using System.Timers
@using YTDLHub.Core.Interfaces
@using YTDLHub.Core.Models
@using YTDLHub.Core.Enums
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable
@inject IDownloadService DownloadService
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize]

<PageTitle>داشبورد - YTDLHub</PageTitle>

<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h2 class="h4 mb-1">داشبورد</h2>
        <p class="text-muted" style="font-size: 13px;">دانلودهای در حال انجام شما</p>
    </div>
</div>

@if (!Jobs.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox mb-3" style="font-size: 48px; opacity: 0.5;"></i>
        <div>هیچ دانلودی در حال انجام نیست.</div>
    </div>
}
else
{
    <div class="row">
        @foreach (var job in Jobs)
        {
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100" style="background-color: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden;">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-start mb-3">
                            <div class="me-3">
                                @if (job.Platform == Platform.YouTube)
                                {
                                    <i class="bi bi-youtube text-danger fs-3"></i>
                                }
                                else if (job.Platform == Platform.Instagram)
                                {
                                    <i class="bi bi-instagram text-warning fs-3"></i>
                                }
                                else
                                {
                                    <i class="bi bi-link-45deg text-primary fs-3"></i>
                                }
                            </div>
                            <div class="flex-grow-1" style="min-width: 0;">
                                <h6 class="mb-1 text-truncate" dir="ltr" style="text-align: right;">
                                    @(job.VideoTitle ?? job.Url)
                                </h6>
                                <div class="text-muted" style="font-size: 12px;">
                                    @job.Quality.ToString()
                                </div>
                            </div>
                        </div>

                        <div class="mb-2 d-flex justify-content-between align-items-center" style="font-size: 12px;">
                            <span class="badge" style="background-color: var(--border-light);">@job.Status</span>
                            @if (job.Status == JobStatus.Downloading)
                            {
                                <span class="text-muted" dir="ltr">@job.SpeedDisplay | @job.EtaDisplay</span>
                            }
                        </div>

                        @if (job.Status == JobStatus.Downloading || job.Status == JobStatus.Merging)
                        {
                            <div class="progress mt-2" style="height: 6px; background-color: var(--border-light); border-radius: 4px;">
                                <div class="progress-bar" role="progressbar" style="width: @(job.Progress)%; background-color: var(--primary);" aria-valuenow="@job.Progress" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        }
                    </div>
                    @if (job.Status == JobStatus.Completed)
                    {
                        <div class="card-footer bg-transparent border-0 p-3 pt-0 text-end">
                            <a href="/api/files/download/@job.Id" class="btn btn-sm btn-primary" target="_blank">
                                <i class="bi bi-download me-1"></i> دریافت فایل
                            </a>
                        </div>
                    }
                    else if (job.Status == JobStatus.Failed)
                    {
                        <div class="card-footer bg-transparent border-0 p-3 pt-0">
                            <div class="text-danger" style="font-size: 12px;"><i class="bi bi-exclamation-triangle me-1"></i> @job.ErrorMessage</div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

<style>
    .badge {
        padding: 4px 8px;
        border-radius: 4px;
        font-weight: 500;
        color: var(--text);
    }
</style>

@code {
    private IEnumerable<DownloadJob> Jobs = new List<DownloadJob>();
    private Timer? _timer;
    private Guid UserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var userIdStr = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(userIdStr, out UserId))
            {
                RefreshData();
                _timer = new Timer(1000);
                _timer.Elapsed += (sender, args) =>
                {
                    RefreshData();
                    InvokeAsync(StateHasChanged);
                };
                _timer.Start();
            }
        }
    }

    private void RefreshData()
    {
        Jobs = DownloadService.GetAllJobs()
            .Where(j => j.UserId == UserId && j.Status != JobStatus.Completed && j.Status != JobStatus.Failed)
            .OrderByDescending(j => j.CreatedAt)
            .ToList();
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
