@page "/folders"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using YTDLHub.Core.Models
@using YTDLHub.Core.Interfaces
@using YTDLHub.Infrastructure.Data
@inject AppDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@attribute [Authorize]

<PageTitle>پوشه‌های من - YTDLHub</PageTitle>

<div class="form-page">
    <div class="form-header">
        <div class="form-header-logo">
            <div class="company-logo">YTDLHub</div>
        </div>
        <div class="form-header-title d-flex justify-content-between align-items-center w-100 pe-4">
            <h1>پوشه‌های من</h1>
            <button class="btn-primary-rtl btn-sm d-flex align-items-center gap-2" @onclick="ShowAddFolderModal">
                <i class="bi bi-folder-plus"></i> پوشه جدید
            </button>
        </div>
        <div class="form-header-info text-center text-muted" style="font-size: 0.85rem; padding-left: 1rem;">
            مدیریت پوشه‌های دانلود برای دسته‌بندی فایل‌ها
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="step-card text-center py-5">
            <div class="empty-state">
                <span class="spinner" style="width: 48px; height: 48px; border-width: 4px;"></span>
                <div class="empty-title mt-3">در حال دریافت پوشه‌ها...</div>
            </div>
        </div>
    }
    else if (!UserFoldersList.Any())
    {
        <div class="step-card">
            <div class="empty-state">
                <i class="bi bi-folder2-open empty-icon"></i>
                <div class="empty-title">پوشه‌ای یافت نشد.</div>
                <div class="empty-sub">شما هنوز هیچ پوشه‌ای ایجاد نکرده‌اید.</div>
            </div>
        </div>
    }
    else
    {
        <div class="folder-grid">
            @foreach (var folder in UserFoldersList)
            {
                <div class="step-card folder-card">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <i class="bi bi-folder-fill" style="font-size: 32px; color: var(--primary);"></i>
                        <button class="btn btn-sm btn-ghost text-danger" style="padding: 4px 8px;" @onclick="() => DeleteFolder(folder.Id)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                    <h3 class="folder-name mb-1">@folder.Name</h3>
                    <div class="text-muted mt-2" style="font-size: 12px;">
                        <span class="badge badge-queued">تعداد دانلودها: @folder.Downloads.Count</span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (ShowModal)
{
    <div class="modal-backdrop">
        <div class="modal-content shadow-lg step-card">
            <h3 class="h5 mb-4 border-bottom pb-2" style="border-color: var(--border) !important;">ایجاد پوشه جدید</h3>
            
            <EditForm Model="NewFolder" OnValidSubmit="SaveFolder">
                <div class="input-group-rtl mb-4" style="flex-direction: column; align-items: stretch; gap: 0.5rem;">
                    <label>نام پوشه</label>
                    <InputText @bind-Value="NewFolder.Name" class="form-control-rtl w-100" placeholder="مثلاً ویدیوهای آموزشی" required />
                </div>
                
                <div class="d-flex justify-content-end gap-2 mt-4">
                    <button type="button" class="btn btn-ghost px-4" @onclick="() => ShowModal = false">انصراف</button>
                    <button type="submit" class="btn-primary-rtl px-4">ذخیره</button>
                </div>
            </EditForm>
        </div>
    </div>
}

<style>
    .folder-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1.5rem;
    }
    .folder-card {
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
    }
    .folder-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.2) !important;
        border-color: var(--primary-glow);
    }
    .folder-name {
        font-size: 16px;
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .modal-backdrop {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1050;
    }
    .modal-content {
        width: 100%;
        max-width: 400px;
    }
</style>

@code {
    private bool IsLoading = true;
    private bool ShowModal = false;
    private Guid UserId;
    private List<UserFolder> UserFoldersList = new();
    private FolderForm NewFolder = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var userIdStr = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(userIdStr, out UserId))
            {
                await LoadFolders();
            }
        }
    }

    private async Task LoadFolders()
    {
        IsLoading = true;
        UserFoldersList = DbContext.Folders
            .Where(f => f.UserId == UserId)
            .Select(f => new UserFolder
            {
                Id = f.Id,
                Name = f.Name,
                Downloads = DbContext.DownloadJobs.Where(d => d.FolderId == f.Id).ToList()
            })
            .ToList();
            
        IsLoading = false;
    }

    private void ShowAddFolderModal()
    {
        NewFolder = new FolderForm();
        ShowModal = true;
    }

    private async Task SaveFolder()
    {
        if (string.IsNullOrWhiteSpace(NewFolder.Name)) return;

        var folder = new UserFolder
        {
            UserId = UserId,
            Name = NewFolder.Name
        };

        DbContext.Folders.Add(folder);
        await DbContext.SaveChangesAsync();

        ShowModal = false;
        await LoadFolders();
    }

    private async Task DeleteFolder(Guid folderId)
    {
        var folder = await DbContext.Folders.FindAsync(folderId);
        if (folder != null && folder.UserId == UserId)
        {
            DbContext.Folders.Remove(folder);
            
            var jobs = DbContext.DownloadJobs.Where(j => j.FolderId == folderId);
            foreach(var job in jobs) job.FolderId = null;

            await DbContext.SaveChangesAsync();
            await LoadFolders();
        }
    }

    public class FolderForm
    {
        public string Name { get; set; } = string.Empty;
    }
}
