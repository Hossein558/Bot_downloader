@page "/login"
@layout EmptyLayout
@rendermode InteractiveServer
@using YTDLHub.Core.Interfaces
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>ورود — YTDLHub</PageTitle>

<div class="auth-shell">
    <div class="auth-bg-glow"></div>

    <div class="auth-card">
        <div class="auth-brand">
            <div class="auth-logo-wrap">
                <i class="bi bi-cloud-arrow-down-fill"></i>
            </div>
            <h1 class="auth-title">YTDLHub</h1>
            <p class="auth-subtitle">پنل حرفه‌ای دانلود محتوا</p>
        </div>

        <div class="auth-form-section">
            <h2 class="auth-form-title">ورود به حساب</h2>

            <EditForm Model="Model" OnValidSubmit="HandleLogin" FormName="login-form">
                <div class="auth-field">
                    <label class="auth-label">
                        <i class="bi bi-person-fill"></i>
                        نام کاربری
                    </label>
                    <InputText @bind-Value="Model.Username"
                               class="auth-input"
                               placeholder="نام کاربری خود را وارد کنید"
                               autocomplete="username"
                               dir="ltr" />
                </div>

                <div class="auth-field">
                    <label class="auth-label">
                        <i class="bi bi-lock-fill"></i>
                        رمز عبور
                    </label>
                    <div class="auth-input-wrap">
                        <InputText @bind-Value="Model.Password"
                                   type="@(ShowPassword ? "text" : "password")"
                                   class="auth-input"
                                   placeholder="رمز عبور خود را وارد کنید"
                                   autocomplete="current-password"
                                   dir="ltr" />
                        <button type="button" class="auth-eye-btn" @onclick="() => ShowPassword = !ShowPassword" tabindex="-1">
                            <i class="bi @(ShowPassword ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Error))
                {
                    <div class="auth-alert auth-alert-error">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        @Error
                    </div>
                }

                <button type="submit" class="auth-btn-primary" disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span class="auth-spinner"></span>
                        <span>در حال ورود...</span>
                    }
                    else
                    {
                        <i class="bi bi-box-arrow-in-left"></i>
                        <span>ورود به پنل</span>
                    }
                </button>
            </EditForm>

            <div class="auth-divider">
                <span>حساب ندارید؟</span>
            </div>

            <a href="/register" class="auth-btn-secondary">
                <i class="bi bi-person-plus-fill"></i>
                ایجاد حساب جدید
            </a>
        </div>
    </div>
</div>

@code {
    private LoginModel Model = new();
    private bool IsLoading = false;
    private bool ShowPassword = false;
    private string Error = string.Empty;

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(Model.Username) || string.IsNullOrWhiteSpace(Model.Password))
        {
            Error = "لطفاً نام کاربری و رمز عبور را وارد کنید.";
            return;
        }

        IsLoading = true;
        Error = string.Empty;
        StateHasChanged();

        var user = await AuthService.LoginAsync(Model.Username, Model.Password);

        IsLoading = false;

        if (user != null)
        {
            Nav.NavigateTo($"/auth/signin?userId={user.Id}", forceLoad: true);
        }
        else
        {
            Error = "نام کاربری یا رمز عبور اشتباه است.";
        }
    }

    public class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
