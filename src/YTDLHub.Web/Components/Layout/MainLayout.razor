@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="shell">
    <!-- Sidebar -->
    <aside class="sidebar @(SidebarOpen ? "" : "collapsed")">
        <div class="sidebar-brand">
            <div class="sidebar-brand-logo">▼</div>
            <span class="sidebar-brand-name">YTDLHub</span>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section">
                <div class="nav-section-label">منو اصلی</div>

                <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                    <svg class="nav-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                        <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                    </svg>
                    داشبورد
                </NavLink>

                <NavLink class="nav-item" href="downloads">
                    <svg class="nav-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2v13m0 0l-4-4m4 4l4-4M2 17v2a2 2 0 002 2h16a2 2 0 002-2v-2"/>
                    </svg>
                    دانلود جدید
                </NavLink>

                <NavLink class="nav-item" href="folders">
                    <svg class="nav-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/>
                    </svg>
                    پوشه‌ها
                </NavLink>

                <NavLink class="nav-item" href="history">
                    <svg class="nav-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                    </svg>
                    تاریخچه
                </NavLink>
            </div>
        </nav>

        <div class="sidebar-footer">
            <div class="user-card" @onclick="Logout">
                <div class="user-avatar">@GetInitials()</div>
                <div class="user-info">
                    <div class="user-name">@(UserName ?? "کاربر")</div>
                    <div class="user-id">خروج از حساب</div>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Area -->
    <div class="main-area">
        <!-- Topbar -->
        <header class="topbar">
            <button class="topbar-toggle" @onclick="ToggleSidebar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>
            <div class="topbar-title">@PageTitle</div>
            <div class="topbar-actions">
                <span style="font-size:11px; color:var(--text-muted);">نسخه ۱.۰</span>
            </div>
        </header>

        <!-- Page Content -->
        <div class="content">
            <CascadingValue Value="this">
                @Body
            </CascadingValue>
        </div>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    خطایی رخ داده است. <a href="." class="reload">بارگذاری مجدد</a>
    <span class="dismiss">✕</span>
</div>

@code {
    [CascadingParameter] public string? UserName { get; set; }

    private bool SidebarOpen = true;
    public string PageTitle = "داشبورد";

    private void ToggleSidebar() => SidebarOpen = !SidebarOpen;

    private string GetInitials()
    {
        if (string.IsNullOrEmpty(UserName)) return "U";
        return UserName.Length > 0 ? UserName[0].ToString().ToUpper() : "U";
    }

    private async Task Logout()
    {
        Nav.NavigateTo("/logout", forceLoad: true);
    }
}
