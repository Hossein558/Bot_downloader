@inherits LayoutComponentBase
@using Syncfusion.Blazor.Navigations

<div id="wrapper">
    <!-- Header / AppBar -->
    <header class="header">
        <nav class="navbar navbar-dark bg-dark px-3 shadow-sm" style="height: 60px;">
            <div class="d-flex align-items-center">
                <button class="btn btn-outline-light me-3 border-0" @onclick="ToggleSidebar">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <span class="navbar-brand mb-0 h1 fw-bold text-white">YTDL Hub</span>
            </div>
            <div class="d-flex align-items-center">
                <span class="text-white-50 small me-3">Syncfusion Powered</span>
            </div>
        </nav>
    </header>

    <!-- Sidebar & Main Content Wrapper -->
    <div class="d-flex" style="height: calc(100vh - 60px);">
        <SfSidebar Width="250px" Target=".main-content" MediaQuery="(min-width: 768px)" @bind-IsOpen="SidebarIsOpen" Type="SidebarType.Auto" class="bg-dark text-white border-end border-secondary shadow">
            <ChildContent>
                <div class="p-3">
                    <ul class="nav flex-column">
                        <li class="nav-item mb-2">
                            <a class="nav-link text-white d-flex align-items-center" href="" Match="NavLinkMatch.All">
                                <i class="bi bi-house-door me-2"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item mb-2">
                            <a class="nav-link text-white-50 d-flex align-items-center" href="downloads">
                                <i class="bi bi-cloud-arrow-down me-2"></i> Downloads
                            </a>
                        </li>
                        <li class="nav-item mb-2">
                            <a class="nav-link text-white-50 d-flex align-items-center" href="settings">
                                <i class="bi bi-gear me-2"></i> Settings
                            </a>
                        </li>
                    </ul>
                </div>
            </ChildContent>
        </SfSidebar>

        <!-- Main Content -->
        <main class="main-content flex-grow-1 overflow-auto bg-black text-light p-4">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool SidebarIsOpen = true;

    private void ToggleSidebar()
    {
        SidebarIsOpen = !SidebarIsOpen;
    }
}
