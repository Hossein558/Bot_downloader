@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row">
            <div class="app-title">
                <span>@PageTitle</span>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="user-info">خوش آمدید، @(UserName ?? "کاربر")</span>
                <button class="btn-danger-rtl btn-sm d-flex align-items-center gap-2" @onclick="Logout">
                    <i class="bi bi-box-arrow-right"></i>
                    خروج
                </button>
            </div>
        </div>

        <article class="content px-4">
            <CascadingValue Value="this">
                @Body
            </CascadingValue>
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    خطایی رخ داده است.
    <a href="" class="reload">بارگذاری مجدد</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    [CascadingParameter] public string? UserName { get; set; }
    public string PageTitle = "داشبورد";

    private void Logout()
    {
        Nav.NavigateTo("/logout", forceLoad: true);
    }
}
